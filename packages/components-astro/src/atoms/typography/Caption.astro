---
/**
 * Caption
 *
 * Small auxiliary text component for metadata, captions, and footnotes.
 * Flexible element type with muted color by default.
 *
 * @param {string} size - Text size (default: "caption")
 *   Options: "caption" | "label" | "footnote"
 * @param {string} weight - Font weight (default: "regular")
 *   Options: "regular" | "medium"
 * @param {string} color - Text color (default: "secondary")
 *   Options: "primary" | "secondary" | "tertiary" | CSS var
 * @param {string} align - Text alignment (default: "left")
 *   Options: "left" | "center" | "right"
 * @param {string} as - HTML element (default: "span")
 *   Options: "span" | "p" | "figcaption"
 * @param {string} class - Additional CSS classes
 *
 * Usage:
 * <Caption>Image caption text</Caption>
 * <Caption as="figcaption">Figure 1: Architecture diagram</Caption>
 * <Caption size="footnote" color="tertiary">Last updated: 2024</Caption>
 * <Caption align="center" weight="medium">Centered caption</Caption>
 */

interface Props {
  size?: "caption" | "label" | "footnote";
  weight?: "regular" | "medium";
  color?: "primary" | "secondary" | "tertiary" | "disabled" | "inherit" | `var(--${string})`;
  align?: "left" | "center" | "right";
  as?: "span" | "p" | "figcaption";
  class?: string;
  [key: string]: any;
}

const {
  size = "caption",
  weight = "regular",
  color = "secondary",
  align = "left",
  as = "span",
  class: className = "",
  ...rest
} = Astro.props;

// ── Resolve color value ──
const semanticColors = ["primary", "secondary", "tertiary", "disabled"] as const;
const isSemanticColor = semanticColors.includes(color as typeof semanticColors[number]);
const isVarRef = typeof color === "string" && color.startsWith("var(--");
const safeColor = (color === "inherit" || isSemanticColor || isVarRef) ? color : "secondary";
const colorStyle = safeColor !== "inherit" && !isSemanticColor ? `color: ${safeColor}` : undefined;

// ── Dynamic HTML Tag ──
const Tag = as;
---

<Tag
  class:list={[
    "caption",
    `caption--${size}`,
    `caption--${weight}`,
    `caption--${align}`,
    { [`caption--${safeColor}`]: isSemanticColor },
    className,
  ]}
  style={colorStyle}
  data-text
  {...rest}
>
  <slot />
</Tag>
