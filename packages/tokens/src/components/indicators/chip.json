{
  "chip": {
    "bg": {
      "$type": "color",
      "$description": "Background colors - supports outlined, filled, and error states",
      "default":              { "$value": "{bg.secondary}" },
      "unselected-enabled":   { "$value": "{bg.interactive.item.enabled}" },
      "unselected-hovered":   { "$value": "{bg.interactive.item.hovered}" },
      "unselected-disabled":  { "$value": "{bg.interactive.item.disabled}" },
      "unselected-pressed":   { "$value": "{bg.interactive.item.pressed}" },
      "selected-enabled":     { "$value": "{bg.interactive.item.selected.enabled}" },
      "selected-hovered":     { "$value": "{bg.interactive.item.selected.hovered}" },
      "selected-disabled":    { "$value": "{bg.interactive.item.selected.disabled}" },
      "selected-pressed":     { "$value": "{bg.interactive.item.selected.pressed}" },
      "outlined-enabled":     { "$value": "{figma.colors.primitive.neutral.0}", "$description": "White background for outlined chips" },
      "outlined-hovered":     { "$value": "{bg.interactive.item.hovered}" },
      "outlined-disabled":    { "$value": "{bg.interactive.item.disabled}" },
      "outlined-pressed":     { "$value": "{bg.interactive.item.pressed}" },
      "outlined-error":       { "$value": "{figma.colors.primitive.zinc.50}", "$description": "Light background for outlined error chips" },
      "filled-enabled":       { "$value": "{figma.colors.primitive.zinc.100}", "$description": "Gray background for filled chips" },
      "filled-hovered":       { "$value": "{bg.interactive.item.hovered}" },
      "filled-disabled":      { "$value": "{bg.interactive.item.disabled}" },
      "filled-pressed":       { "$value": "{bg.interactive.item.pressed}" },
      "filled-error":         { "$value": "{figma.colors.primitive.zinc.50}", "$description": "Light background for filled error chips" }
    },
    "fg": {
      "$type": "color",
      "$description": "Foreground (text/icon) colors",
      "unselected-enabled":  { "$value": "{fg.secondary}" },
      "unselected-hovered":  { "$value": "{fg.primary}" },
      "unselected-disabled": { "$value": "{fg.disabled}" },
      "unselected-pressed":  { "$value": "{fg.primary}" },
      "selected-enabled":    { "$value": "{fg.brand}" },
      "selected-hovered":    { "$value": "{fg.brand}" },
      "selected-disabled":   { "$value": "{fg.disabled}" },
      "selected-pressed":    { "$value": "{fg.brand}" },
      "outlined-enabled":    { "$value": "{fg.secondary}" },
      "outlined-hovered":    { "$value": "{fg.primary}" },
      "outlined-disabled":   { "$value": "{fg.disabled}" },
      "outlined-pressed":    { "$value": "{fg.primary}" },
      "outlined-error":      { "$value": "{figma.colors.primitive.red.700}", "$description": "Red text for outlined error chips" },
      "filled-enabled":      { "$value": "{fg.secondary}" },
      "filled-hovered":      { "$value": "{fg.primary}" },
      "filled-disabled":     { "$value": "{fg.disabled}" },
      "filled-pressed":      { "$value": "{fg.primary}" },
      "filled-error":        { "$value": "{figma.colors.primitive.red.700}", "$description": "Red text for filled error chips" }
    },
    "border": {
      "$type": "color",
      "$description": "Border colors for outlined variant",
      "default":         { "$value": "{border.secondary}" },
      "outlined-enabled": { "$value": "{figma.colors.primitive.zinc.500}", "$description": "Gray border for outlined chips" },
      "outlined-hovered": { "$value": "{figma.colors.primitive.zinc.600}" },
      "outlined-disabled": { "$value": "{border.disabled}" },
      "outlined-pressed": { "$value": "{figma.colors.primitive.zinc.600}" },
      "outlined-error":   { "$value": "{figma.colors.primitive.red.700}", "$description": "Red border for outlined error chips" }
    },
    "shadow": {
      "$type": "shadow",
      "focus": { "$value": "0px 0px 0px 2px rgba(161, 161, 161, 0.7)" }
    },
    "padding": {
      "$type": "dimension",
      "$description": "Note: xs uses asymmetric padding (different x/y), defined in CSS as shorthand",
      "xs": { "$value": "{Primitive.Spacing.xs}", "$description": "4px vertical — horizontal defined in CSS" },
      "s":  { "$value": "{Primitive.Spacing.s}", "$description": "8px" },
      "m":  { "$value": "{Primitive.Spacing.sm}", "$description": "12px" },
      "l":  { "$value": "{Primitive.Spacing.m}", "$description": "16px" },
      "xl": { "$value": "{Primitive.Spacing.m}", "$description": "16px" }
    },
    "font-family": {
      "$type": "fontFamily",
      "small": { "$value": "{font-family-titles}", "$description": "Display font for small chips" },
      "large": { "$value": "{font-body}", "$description": "Body font for large chips" }
    },
    "font-weight": { "$type": "fontWeight", "$value": "{font-weight-medium}", "$description": "500" },
    "font-size": {
      "$type": "dimension",
      "small": { "$value": "12px" },
      "large": { "$value": "{text-caption}", "$description": "16px" }
    },
    "line-height": {
      "$type": "dimension",
      "small": { "$value": "{line-height-label}", "$description": "16px" },
      "large": { "$value": "{line-height-caption}", "$description": "24px" }
    },
    "border-radius": { "$type": "dimension", "$value": "{Primitive.Radius.s}", "$description": "8px — rounded corners" },
    "border-width":  { "$type": "dimension", "$value": "{stroke-xs}", "$description": "1px" },
    "icon-size":     { "$type": "dimension", "$value": "{icon.s}", "$description": "16px" },
    "gap":           { "$type": "dimension", "$value": "{Primitive.Spacing.xs}", "$description": "4px — between icon and label" }
  }
}
