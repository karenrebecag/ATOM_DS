---
/**
 * Inline (Layout Primitive)
 *
 * Horizontal flex layout with consistent gap between children.
 * Use for tag lists, breadcrumbs, button groups, or any horizontally-arranged content.
 * Wraps by default for responsive behavior.
 *
 * @param {"xs" | "s" | "m" | "l" | "xl"} gap - Space between children (default: "m")
 * @param {"start" | "center" | "end" | "baseline"} align - Vertical alignment (default: "center")
 * @param {"start" | "center" | "end" | "between" | "around"} justify - Horizontal alignment (default: "start")
 * @param {boolean} nowrap - Prevent wrapping (default: false)
 * @param {string} as - HTML element tag (default: "div")
 * @param {string} class - Additional CSS classes
 *
 * Usage:
 * <Inline gap="s">
 *   <Tag>React</Tag>
 *   <Tag>TypeScript</Tag>
 *   <Tag>Astro</Tag>
 * </Inline>
 *
 * <Inline gap="m" justify="between">
 *   <Logo />
 *   <Nav />
 * </Inline>
 *
 * @see packages/css/src/layout/inline.css
 * @see packages/tokens/src/components/layout.json
 */

interface Props {
  gap?: "xs" | "s" | "m" | "l" | "xl";
  align?: "start" | "center" | "end" | "baseline";
  justify?: "start" | "center" | "end" | "between" | "around";
  nowrap?: boolean;
  as?: string;
  class?: string;
  [key: string]: any;
}

const {
  gap = "m",
  align = "center",
  justify = "start",
  nowrap = false,
  as = "div",
  class: className = "",
  ...rest
} = Astro.props;

const Element = as;
---

<Element
  class:list={[
    "inline",
    `inline--gap-${gap}`,
    align !== "center" && `inline--align-${align}`,
    justify !== "start" && `inline--justify-${justify}`,
    nowrap && "inline--nowrap",
    className
  ]}
  data-inline
  {...rest}
>
  <slot />
</Element>
