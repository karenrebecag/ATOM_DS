{
  "name": "@atomchat.io/components-vue",
  "version": "1.0.0",
  "description": "ATOM Design System — Vue 3 component library",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./atoms": {
      "import": {
        "types": "./dist/atoms/index.d.ts",
        "default": "./dist/atoms/index.js"
      },
      "require": {
        "types": "./dist/atoms/index.d.cts",
        "default": "./dist/atoms/index.cjs"
      }
    },
    "./atoms/*": {
      "import": {
        "types": "./dist/atoms/*.d.ts",
        "default": "./dist/atoms/*.js"
      },
      "require": {
        "types": "./dist/atoms/*.d.cts",
        "default": "./dist/atoms/*.cjs"
      }
    },
    "./molecules": {
      "import": {
        "types": "./dist/molecules/index.d.ts",
        "default": "./dist/molecules/index.js"
      },
      "require": {
        "types": "./dist/molecules/index.d.cts",
        "default": "./dist/molecules/index.cjs"
      }
    },
    "./molecules/*": {
      "import": {
        "types": "./dist/molecules/*.d.ts",
        "default": "./dist/molecules/*.js"
      },
      "require": {
        "types": "./dist/molecules/*.d.cts",
        "default": "./dist/molecules/*.cjs"
      }
    },
    "./layout": {
      "import": {
        "types": "./dist/layout/index.d.ts",
        "default": "./dist/layout/index.js"
      },
      "require": {
        "types": "./dist/layout/index.d.cts",
        "default": "./dist/layout/index.cjs"
      }
    },
    "./layout/*": {
      "import": {
        "types": "./dist/layout/*.d.ts",
        "default": "./dist/layout/*.js"
      },
      "require": {
        "types": "./dist/layout/*.d.cts",
        "default": "./dist/layout/*.cjs"
      }
    },
    "./composables": {
      "import": {
        "types": "./dist/composables/index.d.ts",
        "default": "./dist/composables/index.js"
      },
      "require": {
        "types": "./dist/composables/index.d.cts",
        "default": "./dist/composables/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vue-tsc --noEmit && vite build",
    "typecheck": "vue-tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "vue": "^3.4.0",
    "@atomchat.io/css": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@atomchat.io/tokens": {
      "optional": true
    }
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.1.0",
    "@vue/tsconfig": "^0.7.0",
    "typescript": "^5.8.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vue": "^3.5.0",
    "vue-tsc": "^2.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/atomchat/atom-design-system.git",
    "directory": "packages/components-vue"
  },
  "keywords": [
    "vue",
    "vue3",
    "design-system",
    "components",
    "atom",
    "atomchat",
    "ui",
    "composition-api",
    "typescript"
  ],
  "license": "MIT",
  "sideEffects": false
}
