---
/**
 * Chip — Filterable tag component
 * @atomchat/components-astro
 *
 * Depends on:
 *   @atomchat/tokens (--chip-* custom properties)
 *   @atomchat/css (chip.css)
 *
 * Props:
 *   size?       "xs" | "s" | "m" | "l" | "xl" - Chip size (default: "m")
 *   selected?   boolean - Selected state (default: false)
 *   disabled?   boolean - Disabled state (default: false)
 *   dismissible? boolean - Show close icon (default: false)
 *   class?      string - Additional CSS classes
 *   onclick?    string - Click handler for the chip
 *   onDismiss?  string - Click handler for dismiss button (dismissible mode)
 *
 * Slots:
 *   default      - Chip label text
 *   icon-start   - Leading icon (optional, replaces default filter icon)
 *   icon-end     - Trailing icon (optional, only shown if not dismissible)
 *
 * Design Notes (from Figma):
 *   - Border radius: 8px (not pill-shaped)
 *   - XS size uses asymmetric padding: 4px vertical, 8px horizontal
 *   - Focus state shows 1px border + 2px shadow ring
 *   - Default icons: filter (leading) + close X (trailing for dismissible)
 */

interface Props {
  size?: "xs" | "s" | "m" | "l" | "xl";
  selected?: boolean;
  disabled?: boolean;
  dismissible?: boolean;
  class?: string;
  onclick?: string;
  onDismiss?: string;
  [key: string]: any;
}

const {
  size = "m",
  selected = false,
  disabled = false,
  dismissible = false,
  class: className = "",
  onclick,
  onDismiss,
  ...rest
} = Astro.props;

const hasLeadingIcon = Astro.slots.has("icon-start");
const hasTrailingIcon = Astro.slots.has("icon-end") && !dismissible;
const hasLabel = Astro.slots.has("default");
---

<button
  class:list={["chip", className]}
  data-chip
  data-size={size}
  data-selected={selected}
  disabled={disabled}
  type="button"
  onclick={onclick}
  {...rest}
>
  {/* Leading Icon */}
  {hasLeadingIcon ? (
    <span class="chip__icon chip__icon--start" data-chip-icon>
      <slot name="icon-start" />
    </span>
  ) : (
    <span class="chip__icon chip__icon--start chip__icon--default" data-chip-icon aria-hidden="true">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M2 4.5C2 4.22386 2.22386 4 2.5 4H13.5C13.7761 4 14 4.22386 14 4.5C14 4.77614 13.7761 5 13.5 5H2.5C2.22386 5 2 4.77614 2 4.5Z" fill="currentColor"/>
        <path d="M4 8C4 7.72386 4.22386 7.5 4.5 7.5H11.5C11.7761 7.5 12 7.72386 12 8C12 8.27614 11.7761 8.5 11.5 8.5H4.5C4.22386 8.5 4 8.27614 4 8Z" fill="currentColor"/>
        <path d="M6.5 11C6.22386 11 6 11.2239 6 11.5C6 11.7761 6.22386 12 6.5 12H9.5C9.77614 12 10 11.7761 10 11.5C10 11.2239 9.77614 11 9.5 11H6.5Z" fill="currentColor"/>
      </svg>
    </span>
  )}

  {/* Label */}
  {hasLabel && (
    <span class="chip__label" data-chip-label>
      <slot />
    </span>
  )}

  {/* Trailing Icon or Dismiss Button */}
  {dismissible ? (
    <button
      class="chip__dismiss"
      data-chip-dismiss
      type="button"
      onclick={onDismiss}
      aria-label="Remove"
      disabled={disabled}
    >
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708z" fill="currentColor"/>
      </svg>
    </button>
  ) : hasTrailingIcon ? (
    <span class="chip__icon chip__icon--end" data-chip-icon>
      <slot name="icon-end" />
    </span>
  ) : null}
</button>
