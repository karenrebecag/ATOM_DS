---
/**
 * Avatar Group (Molecule)
 *
 * Displays a horizontal group of overlapping avatars with an optional "+N" counter.
 * Commonly used to show multiple participants, collaborators, or members.
 *
 * @param {Array<{src: string, alt?: string}>} avatars - Array of avatar objects
 * @param {number} max - Maximum number of avatars to display before showing "+N" (default: 5)
 * @param {"xs" | "s" | "m" | "l"} size - Size of avatars (default: "s")
 * @param {string} class - Additional CSS classes
 *
 * Usage:
 * <AvatarGroup
 *   avatars={[
 *     {src: "/user1.jpg", alt: "User 1"},
 *     {src: "/user2.jpg", alt: "User 2"},
 *     {src: "/user3.jpg", alt: "User 3"}
 *   ]}
 *   max={3}
 *   size="s"
 * />
 */

import Avatar from "../atoms/Avatar.astro";

interface AvatarItem {
  src: string;
  alt?: string;
}

interface Props {
  avatars: AvatarItem[];
  max?: number;
  size?: "xs" | "s" | "m" | "l";
  class?: string;
  [key: string]: any;
}

const {
  avatars = [],
  max = 5,
  size = "s",
  class: className = "",
  ...rest
} = Astro.props;

const visibleAvatars = avatars.slice(0, max);
const remainingCount = Math.max(0, avatars.length - max);
const showCounter = remainingCount > 0;
---

<div
  class:list={["avatar-group", `avatar-group--${size}`, className]}
  data-avatar-group
  data-size={size}
  role="group"
  aria-label={`${avatars.length} ${avatars.length === 1 ? 'member' : 'members'}`}
  {...rest}
>
  {visibleAvatars.map((avatar, index) => (
    <Avatar
      src={avatar.src}
      alt={avatar.alt}
      size={size}
      shape="circle"
      type="image-border"
      badge="none"
      class="avatar-group__item"
      data-avatar-index={index}
    />
  ))}

  {showCounter && (
    <span
      class="avatar-group__counter"
      data-avatar-counter
      role="status"
      aria-label={`${remainingCount} more ${remainingCount === 1 ? 'member' : 'members'}`}
    >
      +{remainingCount}
    </span>
  )}
</div>

<style>
  .avatar-group {
    display: flex;
    align-items: center;
    padding-right: 8px;
  }

  .avatar-group__item {
    margin-right: -8px;
  }

  .avatar-group__counter {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-right: -8px;
    background-color: var(--bg-tertiary);
    color: var(--fg-primary);
    font-family: var(--font-body);
    font-weight: var(--font-weight-regular);
    font-size: var(--text-label-regular);
    line-height: var(--line-height-label);
    text-align: center;
    white-space: nowrap;
  }

  /* Size-specific styles for counter */
  .avatar-group--xs .avatar-group__counter {
    width: 24px;
    height: 24px;
    border-radius: var(--radius-sm);
    padding: 2px 4px;
  }

  .avatar-group--s .avatar-group__counter {
    width: 32px;
    height: 32px;
    border-radius: var(--radius-m);
    padding: 4px 8px;
  }

  .avatar-group--m .avatar-group__counter {
    width: 40px;
    height: 40px;
    border-radius: var(--radius-md);
    padding: 8px 12px;
  }

  .avatar-group--l .avatar-group__counter {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-l);
    padding: 12px;
  }
</style>
