---
/**
 * Divider — Horizontal rule separator
 * @atomchat/components-astro
 *
 * Depends on:
 *   @atomchat/tokens (--divider-* custom properties)
 *   @atomchat/css (divider.css)
 *
 * Props:
 *   opacity?  number - Custom opacity value (0-1)
 *   class?    string - Additional CSS classes
 */

interface Props {
  opacity?: number;
  class?: string;
}

const {
  opacity,
  class: className = "",
} = Astro.props;
---

<hr
  class:list={["divider", className]}
  style={opacity !== undefined ? `--divider-opacity: ${opacity}` : undefined}
  data-divider
  aria-hidden="true"
/>
