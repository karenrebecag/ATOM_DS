{
  "name": "atom-design-system",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:docs": "pnpm --filter atom-docs dev",
    "lint": "turbo run lint",
    "validate": "node scripts/validate-tokens.js",
    "release": "pnpm build && changeset publish",
    "figma:sync": "node scripts/sync-figma-api.js"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "turbo": "^2.4.0"
  },
  "packageManager": "pnpm@9.0.0"
}
