---
/**
 * Status Icon (Atom)
 *
 * A small circular indicator showing online/offline/idle/inactive status.
 * Can be used standalone or as part of other components (Avatar, etc.).
 *
 * @param {"online" | "offline" | "idle" | "inactive"} status - Status type
 * @param {"xs" | "s" | "m" | "l"} size - Icon size (default: "xs")
 * @param {boolean} hasBorder - Whether to show white border (default: true)
 * @param {string} class - Additional CSS classes
 *
 * Status Colors (Semantic Tokens):
 * - online: var(--fg-accent-indicators-online) → Green (#00c951)
 * - offline: var(--fg-accent-indicators-offline) → Red (#fb2c37)
 * - idle: var(--fg-accent-indicators-idle) → Yellow (#f1b100)
 * - inactive: var(--fg-accent-indicators-inactive) → Gray (#6a7282)
 *
 * Usage:
 * <StatusIcon status="online" size="s" />
 * <StatusIcon status="offline" hasBorder={false} />
 */

interface Props {
  status?: "online" | "offline" | "idle" | "inactive";
  size?: "xs" | "s" | "m" | "l";
  hasBorder?: boolean;
  class?: string;
  [key: string]: any;
}

const {
  status = "online",
  size = "xs",
  hasBorder = true,
  class: className = "",
  ...rest
} = Astro.props;

const statusLabels = {
  online: "Online",
  offline: "Offline",
  idle: "Away",
  inactive: "Inactive",
};
---

<span
  class:list={[
    "status-icon",
    `status-icon--${status}`,
    `status-icon--${size}`,
    hasBorder && "status-icon--bordered",
    className,
  ]}
  data-status-icon
  data-status={status}
  data-size={size}
  role="status"
  aria-label={statusLabels[status]}
  {...rest}
/>

<style>
  .status-icon {
    display: inline-block;
    border-radius: var(--radius-pill);
    box-sizing: border-box;
  }

  /* Size variants */
  .status-icon--xs {
    width: var(--status-icon-structure-size-xs);
    height: var(--status-icon-structure-size-xs);
  }

  .status-icon--s {
    width: var(--status-icon-structure-size-s);
    height: var(--status-icon-structure-size-s);
  }

  .status-icon--m {
    width: var(--status-icon-structure-size-m);
    height: var(--status-icon-structure-size-m);
  }

  .status-icon--l {
    width: var(--status-icon-structure-size-l);
    height: var(--status-icon-structure-size-l);
  }

  /* Border variants - All sizes use same border width per Figma design */
  .status-icon--bordered {
    border: var(--stroke-xs) solid var(--bg-primary);
  }

  /* Status colors */
  .status-icon--online {
    background-color: var(--fg-accent-indicators-online);
  }

  .status-icon--offline {
    background-color: var(--fg-accent-indicators-offline);
  }

  .status-icon--idle {
    background-color: var(--fg-accent-indicators-idle);
  }

  .status-icon--inactive {
    background-color: var(--fg-accent-indicators-inactive);
  }
</style>
