{
  "radio": {
    "bg": {
      "$type": "color",
      "enabled": { "$value": "{bg.primary}", "$description": "Radio background - unchecked default" },
      "checked-enabled": { "$value": "{bg.inverse.primary}", "$description": "Radio background - checked default" },
      "checked-hovered": { "$value": "{bg.interactive.primary.hovered}", "$description": "Radio background - checked hover" },
      "enabled-hovered": { "$value": "{bg.secondary}", "$description": "Radio background - unchecked hover" },
      "enabled-focused": { "$value": "{bg.primary}", "$description": "Radio background - unchecked focus" },
      "checked-focused": { "$value": "{bg.inverse.primary}", "$description": "Radio background - checked focus" },
      "checked-disabled": { "$value": "{bg.disabled}", "$description": "Radio background - checked disabled" },
      "disabled": { "$value": "{bg.disabled}", "$description": "Radio background - unchecked disabled" }
    },
    "fg": {
      "$type": "color",
      "checked-enabled": { "$value": "{fg.inverse.primary}", "$description": "Radio dot color - checked" },
      "checked-hovered": { "$value": "{fg.inverse.primary}", "$description": "Radio dot color - checked hover" },
      "checked-focused": { "$value": "{fg.inverse.primary}", "$description": "Radio dot color - checked focus" },
      "checked-disabled": { "$value": "{fg.disabled}", "$description": "Radio dot color - checked disabled" }
    },
    "border": {
      "$type": "color",
      "enabled": { "$value": "{border.primary}", "$description": "Radio border - unchecked default" },
      "enabled-hovered": { "$value": "{border.secondary}", "$description": "Radio border - unchecked hover" },
      "enabled-focused": { "$value": "{border.primary}", "$description": "Radio border - unchecked focus" },
      "enabled-error": { "$value": "{border.status.error}", "$description": "Radio border - error state" },
      "checked-focused": { "$value": "{border.interactive.link.focused}", "$description": "Radio border - checked focus" },
      "disabled": { "$value": "{border.disabled}", "$description": "Radio border - disabled" }
    },
    "shadow": {
      "$type": "shadow",
      "focus": { "$value": "0px 0px 0px 2px {figma.colors.primitive.alpha.400}", "$description": "Radio focus ring shadow" }
    },
    "structure": {
      "circle": {
        "size": {
          "$type": "dimension",
          "s": { "$value": "16px" },
          "m": { "$value": "24px" }
        },
        "border-width": {
          "$type": "dimension",
          "$value": "2px"
        }
      },
      "dot": {
        "size": {
          "$type": "dimension",
          "s": { "$value": "8px", "$description": "Radio dot size - small (50% of 16px circle)" },
          "m": { "$value": "12px", "$description": "Radio dot size - medium (50% of 24px circle)" }
        }
      }
    },
    "field": {
      "font-size": {
        "$type": "dimension",
        "s": { "$value": "12px" },
        "m": { "$value": "16px" }
      },
      "error-font-size": {
        "$type": "dimension",
        "s": { "$value": "10px" },
        "m": { "$value": "16px" }
      },
      "icon-size": {
        "$type": "dimension",
        "s": { "$value": "12px" },
        "m": { "$value": "16px" }
      }
    }
  }
}
