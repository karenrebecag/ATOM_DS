    },
    "@barba/core": {
      "optional": true
    },
    "@barba/prefetch": {
      "optional": true
    }
  },
  "devDependencies": {
    "gsap": "^3.15.0",
    "typescript": "^5.8.0"
  },
  "license": "MIT"
}
