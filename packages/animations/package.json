      "types": "./dist/vertical-slider.d.ts"
    },
    "./components/forms": {
      "import": "./dist/components/forms/index.js",
      "types": "./dist/components/forms/index.d.ts"
    },
    "./components/navigation": {
      "import": "./dist/components/navigation/index.js",
      "types": "./dist/components/navigation/index.d.ts"
    },
    "./extras/smooth-scroll": {
      "import": "./dist/extras/smooth-scroll.js",
      "types": "./dist/extras/smooth-scroll.d.ts"
    },
    "./extras/transitions": {
      "types": "./dist/extras/transitions.d.ts",
