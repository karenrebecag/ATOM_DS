    },
    "./badge": {
      "import": "./dist/badge.js",
      "types": "./dist/badge.d.ts"
    },
    "./cursor": {
      "import": "./dist/cursor.js",
      "types": "./dist/cursor.d.ts"
    },
    "./draggable-marquee": {
      "import": "./dist/draggable-marquee.js",
      "types": "./dist/draggable-marquee.d.ts"
    },
    "./features": {
      "import": "./dist/features.js",
      "types": "./dist/features.d.ts"
    },
    "./flick-cards": {
      "import": "./dist/flick-cards.js",
      "types": "./dist/flick-cards.d.ts"
    },
    "./footer-logo": {
      "import": "./dist/footer-logo.js",
      "types": "./dist/footer-logo.d.ts"
    },
    "./hover": {
      "import": "./dist/hover.js",
