---
interface Props {
  name: string;
  value?: string;
  size?: "s" | "m";
  checked?: boolean;
  disabled?: boolean;
  supportiveText?: string;
  error?: boolean;
  errorText?: string;
  class?: string;
  [key: string]: any;
}

const {
  name,
  value,
  size = "s",
  checked = false,
  disabled = false,
  supportiveText,
  error = false,
  errorText,
  class: className = "",
  ...rest
} = Astro.props;

const id = `radio-${name}-${value || "default"}`;
const hasLabel = Astro.slots.has("default");
const hasError = error && errorText;
---

{hasLabel || supportiveText || hasError ? (
  <div
    class:list={[
      "radio-field",
      `radio-field--${size}`,
      { "radio-field--disabled": disabled, "radio-field--error": hasError },
      className
    ]}
  >
    <div class="radio-field__row">
      <div class="radio-field__selector">
        <label class:list={["radio", `radio--${size}`]} for={id} data-radio>
          <input
            class="radio__input"
            type="radio"
            id={id}
            name={name}
            value={value}
            checked={checked}
            disabled={disabled}
            {...rest}
          />
          <span class="radio__circle" aria-hidden="true" data-radio-circle>
            <span class="radio__dot" data-radio-dot></span>
          </span>
        </label>
      </div>
      <div class="radio-field__text">
        {hasLabel && (
          <label class="radio-field__title" for={id}>
            <slot />
          </label>
        )}
        {supportiveText && (
          <span class="radio-field__supportive">{supportiveText}</span>
        )}
      </div>
    </div>
    {hasError && (
      <div class="radio-field__error">
        <svg class="radio-field__error-icon" viewBox="0 0 16 16" fill="currentColor">
          <path d="M8 1a7 7 0 1 0 0 14A7 7 0 0 0 8 1Zm-.75 4a.75.75 0 0 1 1.5 0v3.5a.75.75 0 0 1-1.5 0V5Zm.75 7a1 1 0 1 1 0-2 1 1 0 0 1 0 2Z"/>
        </svg>
        <span class="radio-field__error-text">{errorText}</span>
      </div>
    )}
  </div>
) : (
  <label class:list={["radio", `radio--${size}`, { "radio--disabled": disabled }, className]} for={id} data-radio>
    <input
      class="radio__input"
      type="radio"
      id={id}
      name={name}
      value={value}
      checked={checked}
      disabled={disabled}
      {...rest}
    />
    <span class="radio__circle" aria-hidden="true" data-radio-circle>
      <span class="radio__dot" data-radio-dot></span>
    </span>
  </label>
)}
