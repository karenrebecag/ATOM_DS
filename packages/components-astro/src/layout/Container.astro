---
/**
 * Container (Layout Primitive)
 *
 * Max-width centered layout container with responsive horizontal padding.
 * Limits content width and centers horizontally for optimal reading experience.
 *
 * @param {"sm" | "md" | "lg" | "xl" | "2xl" | "full"} size - Container width (default: "lg")
 * @param {string} as - HTML element tag (default: "div")
 * @param {string} class - Additional CSS classes
 *
 * Usage:
 * <Container size="lg">
 *   <h1>Page content</h1>
 * </Container>
 *
 * <Container size="md" as="section">
 *   <article>Blog post</article>
 * </Container>
 *
 * @see packages/css/src/layout/container.css
 * @see packages/tokens/src/components/layout.json
 */

interface Props {
  size?: "sm" | "md" | "lg" | "xl" | "2xl" | "full";
  as?: string;
  class?: string;
  [key: string]: any;
}

const {
  size = "lg",
  as = "div",
  class: className = "",
  ...rest
} = Astro.props;

const Element = as;
---

<Element
  class:list={[
    "container",
    `container--${size}`,
    className
  ]}
  data-container
  {...rest}
>
  <slot />
</Element>
