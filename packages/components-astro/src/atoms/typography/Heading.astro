---
/**
 * Heading
 *
 * Semantic heading component with level/size decoupling.
 * HTML level (h1-h6) can be independent from visual size.
 *
 * @param {1 | 2 | 3 | 4 | 5 | 6} level - HTML heading level (default: 2)
 * @param {string} size - Visual size (default: auto-maps from level)
 *   Options: "display-xl" | "display-l" | "display-m" | "display-s" |
 *            "huge-title" | "h1" | "h2" | "h3" | "h4" | "heading"
 * @param {string} weight - Font weight (default: "bold")
 *   Options: "regular" | "medium" | "bold"
 * @param {string} tracking - Letter spacing (default: "tight")
 *   Options: "tighter" | "tight" | "normal" | "wide" | "wider" | "widest"
 * @param {string} color - Text color CSS var or "inherit" (default: "inherit")
 * @param {string} align - Text alignment (default: "left")
 *   Options: "left" | "center" | "right"
 * @param {boolean} balance - Enable text-wrap: balance (default: false)
 * @param {string | false} animate - Animation type (default: false)
 *   Options: "masked-lines" | "masked-words" | "masked-chars" |
 *            "scramble-load" | "fade-up-load" | "scramble-scroll" | "highlight-scroll"
 * @param {string} trigger - Animation trigger (default: "scroll")
 *   Options: "scroll" | "load"
 * @param {number} delay - Animation delay in seconds (default: 0)
 * @param {string} class - Additional CSS classes
 *
 * Usage:
 * <Heading level={1} size="display-xl">Hero Title</Heading>
 * <Heading level={2} size="h1" animate="masked-lines">Section Title</Heading>
 * <Heading level={3} weight="medium" align="center">Subtitle</Heading>
 */

interface Props {
  level?: 1 | 2 | 3 | 4 | 5 | 6;
  size?: "display-xl" | "display-l" | "display-m" | "display-s" | "huge-title" | "h1" | "h2" | "h3" | "h4" | "heading";
  weight?: "regular" | "medium" | "bold";
  tracking?: "tighter" | "tight" | "normal" | "wide" | "wider" | "widest";
  color?: "primary" | "secondary" | "tertiary" | "disabled" | "inherit" | `var(--${string})`;
  align?: "left" | "center" | "right";
  balance?: boolean;
  animate?: "masked-lines" | "masked-words" | "masked-chars" | "scramble-load" | "fade-up-load" | "scramble-scroll" | "highlight-scroll" | false;
  trigger?: "scroll" | "load";
  delay?: number;
  class?: string;
  [key: string]: any;
}

const {
  level = 2,
  size,
  weight = "bold",
  tracking = "tight",
  color = "inherit",
  align = "left",
  balance = false,
  animate = false,
  trigger = "scroll",
  delay = 0,
  class: className = "",
  ...rest
} = Astro.props;

// ── Validate color value ──
const semanticColors = ["primary", "secondary", "tertiary", "disabled"] as const;
const isSemanticColor = semanticColors.includes(color as typeof semanticColors[number]);
const isVarRef = color.startsWith("var(--");
const safeColor = (color === "inherit" || isSemanticColor || isVarRef) ? color : "inherit";

// ── Level → Size Auto-Mapping ──
const defaultSizeMap = {
  1: "h1",
  2: "h2",
  3: "h3",
  4: "h4",
  5: "heading",
  6: "heading",
} as const;

const resolvedSize = size || defaultSizeMap[level as keyof typeof defaultSizeMap];

// ── Determine split type for SplitText animations ──
const splitType = animate === "masked-chars" ? "chars"
  : animate === "masked-words" ? "words"
  : animate === "masked-lines" ? "lines"
  : undefined;

// ── Dynamic HTML Tag ──
const Tag = `h${level}` as any;
---

<Tag
  class:list={[
    "heading",
    `heading--${resolvedSize}`,
    `heading--${weight}`,
    `heading--${tracking}`,
    `heading--${align}`,
    { "heading--balance": balance },
    { [`heading--${safeColor}`]: isSemanticColor },
    className,
  ]}
  style={safeColor !== "inherit" && !isSemanticColor ? `color: ${safeColor}` : undefined}
  data-text
  data-text-animate={animate || undefined}
  data-text-trigger={animate ? trigger : undefined}
  data-text-split={splitType}
  data-text-delay={delay > 0 ? delay.toString() : undefined}
  {...rest}
>
  <slot />
</Tag>
