---
/**
 * Button (Atom)
 *
 * Primary interactive component with 6 variants and 5 sizes.
 * Supports loading state, disabled state, icons, and link rendering.
 *
 * @param {"Primary" | "Secondary" | "Tertiary" | "Destructive Primary" | "Destructive Secondary" | "Destructive Tertiary"} variant - Button variant (default: "Primary")
 * @param {"xs" | "s" | "m" | "l" | "xl"} size - Button size (default: "m")
 * @param {string} href - If provided, renders as <a> tag instead of <button>
 * @param {"button" | "submit" | "reset"} type - Button type attribute (default: "button")
 * @param {boolean} disabled - Disabled state
 * @param {boolean} loading - Loading state with spinner
 * @param {string} class - Additional CSS classes
 *
 * Slots:
 * - default: Button label text
 * - icon-left: Icon before label
 * - icon-right: Icon after label
 *
 * Data Attributes (Animation Contract):
 * - data-button: Root element (discovery)
 * - data-hover-rotate: Enables hover rotate animation (via @atomchat/animations)
 * - data-shimmer: On loading text (shimmer animation via @atomchat/animations)
 * - data-button-label: Original label (animated on hover)
 * - data-button-label-clone: Clone label (animated on hover)
 * - data-button-spinner: Loading spinner
 *
 * Usage:
 * <Button variant="Primary" size="m">Click me</Button>
 * <Button variant="Secondary" loading>Loading...</Button>
 * <Button variant="Tertiary" href="/about">Link Button</Button>
 * <Button variant="Destructive Primary" disabled>Delete</Button>
 *
 * @see packages/animations/src/hover.ts — initHoverRotate()
 * @see packages/animations/src/loading.ts — initShimmerText()
 */

interface Props {
  variant?: "Primary" | "Secondary" | "Tertiary" | "Destructive Primary" | "Destructive Secondary" | "Destructive Tertiary";
  size?: "xs" | "s" | "m" | "l" | "xl";
  href?: string;
  type?: "button" | "submit" | "reset";
  disabled?: boolean;
  loading?: boolean;
  class?: string;
  [key: string]: any;
}

const {
  variant = "Primary",
  size = "m",
  href,
  type = "button",
  disabled = false,
  loading = false,
  class: className = "",
  ...rest
} = Astro.props;

// Variant mapping (legacy compatibility + typo correction)
const variantMap: Record<string, string> = {
  "Primary": "primary",
  "Secondary": "secondary",
  "Tertiary": "tertiary",
  "Terceary": "tertiary",  // Legacy typo support
  "Destructive Primary": "danger-primary",
  "Destructive Secondary": "danger-secondary",
  "Destructive Tertiary": "danger-tertiary"
};
const tokenVariant = variantMap[variant];

const Tag = href ? "a" : "button";
const hasIconLeft = Astro.slots.has("icon-left");
const hasIconRight = Astro.slots.has("icon-right");
---

<Tag
  class:list={[
    "button",
    `button--${tokenVariant}`,
    `button--${size}`,
    { "button--disabled": disabled, "button--loading": loading },
    className
  ]}
  data-button
  data-hover-rotate
  {...href ? { href } : { type }}
  {...(disabled || loading) && href ? { tabindex: -1 } : {}}
  {...(disabled || loading) ? { disabled: true, "aria-disabled": "true" } : {}}
  {...loading ? { "aria-busy": "true" } : {}}
  {...rest}
>
  {loading ? (
    <span class="button__loading-content">
      <span class="button__loading-text" data-shimmer>Loading</span>
      <span class="button__spinner" data-button-spinner aria-hidden="true"></span>
    </span>
  ) : (
    <span class="button__label-wrap">
      <span class="button__label" data-button-label>
        {hasIconLeft && <span class="button__icon"><slot name="icon-left" /></span>}
        <slot />
        {hasIconRight && <span class="button__icon"><slot name="icon-right" /></span>}
      </span>
      <span class="button__label button__label--clone" data-button-label-clone aria-hidden="true">
        {hasIconLeft && <span class="button__icon"><slot name="icon-left" /></span>}
        <slot />
        {hasIconRight && <span class="button__icon"><slot name="icon-right" /></span>}
      </span>
    </span>
  )}
</Tag>
