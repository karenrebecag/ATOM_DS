{
  "name": "@anthropic-atom/tokens",
  "version": "1.0.0",
  "description": "ATOM Design System tokens — W3C DTCG format, compiled via Style Dictionary",
  "main": "build/js/tokens.cjs",
  "module": "build/js/tokens.js",
  "types": "build/js/tokens.d.ts",
  "exports": {
    ".": {
      "import": "./build/js/tokens.js",
      "require": "./build/js/tokens.cjs",
      "types": "./build/js/tokens.d.ts"
    },
    "./css": "./build/css/tokens.css",
    "./css/foundation": "./build/css/foundation.css",
    "./css/semantic": "./build/css/semantic.css",
    "./css/components": "./build/css/components.css",
    "./css/dark": "./build/css/dark.css",
    "./scss": "./build/scss/_tokens.scss",
    "./json": "./build/json/tokens.json"
  },
  "files": [
    "build/",
    "src/"
  ],
  "scripts": {
    "prebuild": "node ../../scripts/validate-tokens.js",
    "build": "style-dictionary build --config config/style-dictionary.config.mjs && style-dictionary build --config config/style-dictionary.dark.config.mjs",
    "dev": "style-dictionary build --config config/style-dictionary.config.mjs --watch"
  },
  "devDependencies": {
    "style-dictionary": "^4.3.0"
  },
  "keywords": ["design-tokens", "design-system", "w3c-dtcg", "css-variables"],
  "license": "MIT"
}
