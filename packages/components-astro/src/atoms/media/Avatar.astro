---
/**
 * Avatar (User Profile Avatar)
 *
 * Displays user profile images, initials, or icons with optional status badges.
 * Supports multiple types, sizes, shapes, and badge indicators.
 *
 * @param {string} src - Image URL for avatar
 * @param {string} alt - Alt text for image (defaults to initials or "Avatar")
 * @param {"xs" | "s" | "m" | "l"} size - Avatar size variant
 * @param {"circle" | "square"} shape - Avatar shape variant
 * @param {"image" | "image-border" | "initials" | "icon"} type - Avatar type (auto-detected from src)
 * @param {string} initials - Initials to display (e.g., "JD")
 * @param {"verified" | "online" | "offline" | "idle" | "inactive" | "none"} badge - Status badge indicator
 * @param {string} class - Additional CSS classes
 *
 * Architecture:
 * - Status badges (online/offline/idle/inactive) rendered inline
 * - Verified badge renders custom SVG (different visual pattern)
 *
 * Auto-detection Logic:
 * - If src is provided → type defaults to "image-border"
 * - If no src → type defaults to "initials"
 *
 * Icon Slot:
 * - Use <Avatar type="icon"><svg slot="icon">...</svg></Avatar>
 * - Falls back to default user icon SVG if no slot provided
 *
 * Usage:
 * <Avatar src="/user.jpg" size="m" badge="online" />
 * <Avatar initials="JD" size="s" shape="square" />
 * <Avatar type="icon" size="l" badge="verified" />
 */

interface Props {
  src?: string;
  alt?: string;
  size?: "xs" | "s" | "m" | "l";
  shape?: "circle" | "square";
  type?: "image" | "image-border" | "initials" | "icon";
  initials?: string;
  badge?: "verified" | "online" | "offline" | "idle" | "inactive" | "none";
  class?: string;
  [key: string]: any;
}

const {
  src,
  alt = "",
  size = "xs",
  shape = "circle",
  type = src ? "image-border" : "initials",
  initials,
  badge = "none",
  class: className = "",
  ...rest
} = Astro.props;

const hasIcon = Astro.slots.has("icon");

// Map avatar size to StatusIcon size for consistent badge sizing
const statusIconSizeMap: Record<string, "xs" | "s" | "m" | "l"> = {
  xs: "s",  // Avatar XS (24px) → StatusIcon S (10px)
  s: "s",   // Avatar S (32px) → StatusIcon S (10px)
  m: "m",   // Avatar M (40px) → StatusIcon M (12px)
  l: "l",   // Avatar L (48px) → StatusIcon L (16px)
};

const statusIconSize = statusIconSizeMap[size];
const isStatusBadge = badge === "online" || badge === "offline" || badge === "idle" || badge === "inactive";

// Status badge labels for ARIA
const statusLabels = {
  online: "Online",
  offline: "Offline",
  idle: "Away",
  inactive: "Inactive",
};

// Compute aria-label for accessibility
const ariaLabel = alt || initials || "Avatar";
---

<span
  class:list={[
    "avatar",
    `avatar--${size}`,
    `avatar--${shape}`,
    `avatar--${type}`,
    className,
  ]}
  data-avatar
  data-size={size}
  data-shape={shape}
  data-type={type}
  role="img"
  aria-label={ariaLabel}
  {...rest}
>
  {(type === "image" || type === "image-border") && src && (
    <span class="avatar__frame">
      <img
        class="avatar__img"
        data-avatar-img
        src={src}
        alt={alt}
        loading="lazy"
      />
    </span>
  )}

  {type === "initials" && (
    <span class="avatar__initials" data-avatar-initials>
      {initials || "?"}
    </span>
  )}

  {type === "icon" && (
    <span class="avatar__icon" data-avatar-icon>
      {hasIcon ? (
        <slot name="icon" />
      ) : (
        <svg viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM2 14s-1 0-1-1 1-4 7-4 7 3 7 4-1 1-1 1H2Z"/>
        </svg>
      )}
    </span>
  )}

  {/* Badge Indicators */}
  {/* Verified badge: Custom SVG icon (not a StatusIcon) */}
  {badge === "verified" && (
    <span
      class="avatar__badge avatar__badge--verified"
      data-avatar-badge
      data-badge-type="verified"
      aria-label="Verified"
    >
      <svg viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
        <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
      </svg>
    </span>
  )}

  {/* Status badges: Rendered inline (online/offline/idle/inactive) */}
  {isStatusBadge && (
    <span
      class:list={[
        "status-icon",
        "status-icon--bordered",
        `status-icon--${badge}`,
        `status-icon--${statusIconSize}`,
        "avatar__badge"
      ]}
      data-avatar-badge
      data-badge-type={badge}
      data-status={badge}
      data-size={statusIconSize}
      role="status"
      aria-label={statusLabels[badge as keyof typeof statusLabels]}
    />
  )}
</span>
