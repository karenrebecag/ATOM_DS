---
/**
 * Avatar Group (Molecule)
 *
 * Displays a horizontal group of overlapping avatars with an optional "+N" counter.
 * Commonly used to show multiple participants, collaborators, or members.
 * Composes Avatar atoms with shared props passed to all children.
 *
 * @param {Array<{src?: string, alt?: string, initials?: string, badge?: "verified" | "online" | "offline" | "idle" | "inactive" | "none"}>} avatars - Array of avatar objects
 * @param {number} max - Maximum number of avatars to display before showing "+N" (default: 5)
 * @param {"xs" | "s" | "m" | "l"} size - Size of avatars (default: "s")
 * @param {"circle" | "square"} shape - Shape applied to all avatars (default: "circle")
 * @param {"image" | "image-border" | "initials" | "icon"} type - Type applied to all avatars (default: "image-border")
 * @param {string} class - Additional CSS classes
 *
 * Avatar Item Props (per avatar in array):
 * - src?: Image URL
 * - alt?: Alt text for image
 * - initials?: Initials to display (if no src)
 * - badge?: Individual badge override (optional)
 *
 * Usage:
 * <AvatarGroup
 *   avatars={[
 *     {src: "/user1.jpg", alt: "User 1", badge: "online"},
 *     {src: "/user2.jpg", alt: "User 2"},
 *     {initials: "JD", alt: "John Doe"}
 *   ]}
 *   max={3}
 *   size="s"
 *   shape="circle"
 *   type="image-border"
 * />
 *
 * @see packages/css/src/components/avatar-group.css
 * @see packages/components-astro/src/atoms/Avatar.astro
 */

import Avatar from "../atoms/media/Avatar.astro";

interface AvatarItem {
  src?: string;
  alt?: string;
  initials?: string;
  badge?: "verified" | "online" | "offline" | "idle" | "inactive" | "none";
}

interface Props {
  avatars: AvatarItem[];
  max?: number;
  size?: "xs" | "s" | "m" | "l";
  shape?: "circle" | "square";
  type?: "image" | "image-border" | "initials" | "icon";
  class?: string;
  [key: string]: any;
}

const {
  avatars = [],
  max = 5,
  size = "s",
  shape = "circle",
  type = "image-border",
  class: className = "",
  ...rest
} = Astro.props;

const visibleAvatars = avatars.slice(0, max);
const remainingCount = Math.max(0, avatars.length - max);
const showCounter = remainingCount > 0;
---

<div
  class:list={["avatar-group", `avatar-group--${size}`, className]}
  data-avatar-group
  data-size={size}
  data-shape={shape}
  data-type={type}
  role="group"
  aria-label={`${avatars.length} ${avatars.length === 1 ? 'member' : 'members'}`}
  {...rest}
>
  {visibleAvatars.map((avatar, index) => (
    <Avatar
      src={avatar.src}
      alt={avatar.alt}
      initials={avatar.initials}
      size={size}
      shape={shape}
      type={avatar.src ? type : "initials"}
      badge={avatar.badge || "none"}
      class="avatar-group__item"
      data-avatar-index={index}
    />
  ))}

  {showCounter && (
    <span
      class="avatar-group__counter"
      data-avatar-counter
      role="status"
      aria-label={`${remainingCount} more ${remainingCount === 1 ? 'member' : 'members'}`}
    >
      +{remainingCount}
    </span>
  )}
</div>
