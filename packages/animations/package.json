      "import": "./dist/progress-nav.js",
      "types": "./dist/progress-nav.d.ts"
    },
    "./reveal": {
      "import": "./dist/reveal.js",
      "types": "./dist/reveal.d.ts"
    },
    "./rotating-layers": {
      "import": "./dist/rotating-layers.js",
      "types": "./dist/rotating-layers.d.ts"
    },
    "./scroll-direction": {
      "import": "./dist/scroll-direction.js",
      "types": "./dist/scroll-direction.d.ts"
    },
    "./sidebar-wipe": {
      "import": "./dist/sidebar-wipe.js",
      "types": "./dist/sidebar-wipe.d.ts"
    },
    "./slider": {
      "import": "./dist/slider.js",
