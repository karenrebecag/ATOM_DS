{
  "badge": {
    "bg": {
      "$type": "color",
      "neutral": {
        "default":  { "$value": "{figma.colors.primitive.zinc.100}" },
        "focused":  { "$value": "{figma.colors.primitive.zinc.950}" },
        "subtle":   { "$value": "{figma.colors.primitive.zinc.800}" }
      },
      "inbox": {
        "default":  { "$value": "{figma.colors.primitive.red.100}" },
        "focused":  { "$value": "{figma.colors.primitive.red.900}" },
        "subtle":   { "$value": "{figma.colors.primitive.red.500}" }
      },
      "info": {
        "default":  { "$value": "{figma.colors.primitive.blue.100}" },
        "focused":  { "$value": "{figma.colors.primitive.blue.900}" },
        "subtle":   { "$value": "{figma.colors.primitive.blue.500}" }
      }
    },
    "fg": {
      "$type": "color",
      "neutral": {
        "default":  { "$value": "{figma.colors.primitive.zinc.900}" },
        "focused":  { "$value": "{figma.colors.primitive.zinc.50}" },
        "subtle":   { "$value": "{figma.colors.primitive.zinc.50}" }
      },
      "inbox": {
        "default":  { "$value": "{figma.colors.primitive.zinc.900}" },
        "focused":  { "$value": "{figma.colors.primitive.zinc.50}" },
        "subtle":   { "$value": "{figma.colors.primitive.zinc.50}" }
      },
      "info": {
        "default":  { "$value": "{figma.colors.primitive.blue.500}" },
        "focused":  { "$value": "{figma.colors.primitive.zinc.50}" },
        "subtle":   { "$value": "{figma.colors.primitive.zinc.50}" }
      }
    },
    "min-width":      { "$type": "dimension", "$value": "{m}", "$description": "16px" },
    "padding-x":      { "$type": "dimension", "$value": "{xxs}", "$description": "2px" },
    "padding-y":      { "$type": "dimension", "$value": "0px" },
    "border-radius":  { "$type": "dimension", "$value": "{radius-pill}", "$description": "9999px" },
    "font-family":    { "$type": "fontFamily", "$value": "{font-family-titles}" },
    "font-size":      { "$type": "dimension", "$value": "{text-labelSmall-medium}", "$description": "10px" },
    "font-weight":    { "$type": "fontWeight", "$value": "{font-weight-medium}", "$description": "500" },
    "line-height":    { "$type": "dimension", "$value": "{line-height-labelSmall}", "$description": "16px" }
  }
}
