---
/**
 * LegalMeta
 *
 * Metadata display component for legal documents.
 * Shows information like "Last updated", version numbers, effective dates, etc.
 * Typically used at the top of legal pages with subtle styling.
 *
 * @param {string} class - Additional CSS classes
 *
 * Usage:
 * <LegalMeta>
 *   <strong>Last updated:</strong> January 15, 2025
 * </LegalMeta>
 *
 * <LegalMeta>
 *   <strong>Effective date:</strong> March 1, 2025<br/>
 *   <strong>Version:</strong> 2.0
 * </LegalMeta>
 *
 * @see packages/css/src/atoms/legal-meta.css
 */

interface Props {
  class?: string;
  [key: string]: any;
}

const {
  class: className = "",
  ...rest
} = Astro.props;
---

<div
  class:list={[
    "legal-meta",
    className
  ]}
  {...rest}
>
  <slot />
</div>
