{
  "Primitive": {
    "Glass": {
      "Blur": {
        "$type": "dimension",
        "subtle":  { "$value": "8px" },
        "default": { "$value": "16px" },
        "strong":  { "$value": "24px" },
        "intense": { "$value": "32px" }
      },
      "BgOpacity": {
        "$type": "number",
        "subtle": { "$value": 0.08 },
        "light":  { "$value": 0.15 },
        "medium": { "$value": 0.22 },
        "strong": { "$value": 0.3 }
      },
      "BorderOpacity": {
        "$type": "number",
        "subtle": { "$value": 0.3 },
        "medium": { "$value": 0.5 },
        "strong": { "$value": 0.7 }
      },
      "NoiseScale": {
        "$type": "number",
        "subtle":  { "$value": 0.5 },
        "medium":  { "$value": 1 },
        "strong":  { "$value": 1.4 },
        "intense": { "$value": 2 }
      },
      "SaturationBoost": {
        "$type": "number",
        "default": { "$value": 180 }
      }
    }
  }
}
