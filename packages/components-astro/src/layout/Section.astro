---
/**
 * Section (Layout Primitive)
 *
 * Semantic HTML5 <section> with consistent vertical spacing.
 * Use to separate major page sections with breathing room.
 * Automatically reduces padding on mobile for better UX.
 *
 * @param {"xs" | "s" | "m" | "l" | "xl"} size - Vertical padding size (default: "m")
 * @param {string} as - HTML element tag (default: "section")
 * @param {string} class - Additional CSS classes
 *
 * Usage:
 * <Section size="l">
 *   <Container>
 *     <h2>Features</h2>
 *     <FeatureGrid />
 *   </Container>
 * </Section>
 *
 * <Section size="xl" as="main">
 *   <!-- Hero section with extra padding -->
 *   <Hero />
 * </Section>
 *
 * @see packages/css/src/layout/section.css
 * @see packages/tokens/src/components/layout.json
 */

interface Props {
  size?: "xs" | "s" | "m" | "l" | "xl";
  as?: string;
  class?: string;
  [key: string]: any;
}

const {
  size = "m",
  as = "section",
  class: className = "",
  ...rest
} = Astro.props;

const Element = as;
---

<Element
  class:list={[
    "section",
    `section--${size}`,
    className
  ]}
  data-section
  {...rest}
>
  <slot />
</Element>
