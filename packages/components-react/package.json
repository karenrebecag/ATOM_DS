{
  "name": "@atomchat.io/components-react",
  "version": "2.0.0",
  "description": "ATOM Design System — React component library",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./atoms/*": {
      "types": "./dist/atoms/*.d.ts",
      "import": "./dist/atoms/*.js",
      "require": "./dist/atoms/*.cjs"
    },
    "./molecules/*": {
      "types": "./dist/molecules/*.d.ts",
      "import": "./dist/molecules/*.js",
      "require": "./dist/molecules/*.cjs"
    },
    "./organisms/*": {
      "types": "./dist/organisms/*.d.ts",
      "import": "./dist/organisms/*.js",
      "require": "./dist/organisms/*.cjs"
    },
    "./layout/*": {
      "types": "./dist/layout/*.d.ts",
      "import": "./dist/layout/*.js",
      "require": "./dist/layout/*.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "@atomchat.io/css": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.8.3"
  },
  "keywords": [
    "react",
    "design-system",
    "components",
    "ui",
    "atom",
    "atomchat"
  ],
  "license": "MIT"
}
