---
/**
 * Tag (Atom)
 *
 * Status indicator with semantic colors and multiple visual styles.
 * Supports 8 semantic states (success, warning, danger, info, neutral, brand, ai, disabled)
 * 3 variants (ghost, filled, outlined), and 3 sizes (xs, s, m).
 *
 * @param {"success" | "warning" | "danger" | "info" | "neutral" | "brand" | "ai" | "disabled"} intent - Semantic state (default: "success")
 * @param {"ghost" | "filled" | "outlined"} variant - Visual style variant (default: "filled")
 * @param {"xs" | "s" | "m"} size - Size variant (default: "m")
 * @param {boolean} hasDots - Show status dot indicator (default: false)
 * @param {boolean} disabled - Disabled state (default: false)
 * @param {string} class - Additional CSS classes
 *
 * Slots:
 * - default: Tag label text
 * - icon: Icon element (16px)
 * - avatar: Avatar element (24px)
 *
 * Data Attributes (Animation Contract):
 * - data-tag: Root element (discovery)
 * - data-tag-dot: Status dot element
 * - data-tag-text: Text content element
 *
 * Usage:
 * <Tag intent="success" variant="filled">Active</Tag>
 * <Tag intent="warning" variant="outlined">Pending</Tag>
 * <Tag intent="danger" variant="ghost" hasDots>Error</Tag>
 * <Tag intent="info" size="xs">
 *   <svg slot="icon">...</svg>
 *   With Icon
 * </Tag>
 * <Tag intent="brand" size="s">
 *   <Avatar slot="avatar" size="xs" />
 *   With Avatar
 * </Tag>
 *
 * @see packages/css/src/components/indicators/tag.css
 * @see packages/tokens/src/components/indicators/tag.json
 */

interface Props {
  intent?: "success" | "warning" | "danger" | "info" | "neutral" | "brand" | "ai" | "disabled";
  variant?: "ghost" | "filled" | "outlined";
  size?: "xs" | "s" | "m";
  hasDots?: boolean;
  disabled?: boolean;
  class?: string;
  [key: string]: any;
}

const {
  intent = "success",
  variant = "filled",
  size = "m",
  hasDots = false,
  disabled = false,
  class: className = "",
  ...rest
} = Astro.props;

const hasIcon = Astro.slots.has("icon");
const hasAvatar = Astro.slots.has("avatar");

// If disabled prop is true, override intent with "disabled"
const finalIntent = disabled ? "disabled" : intent;
---

<span
  class:list={[
    "tag",
    finalIntent && `tag--${finalIntent}`,
    `tag--${variant}`,
    `tag--${size}`,
    className
  ]}
  data-tag
  {...rest}
>
  {hasDots && <span class="tag__dot" aria-hidden="true" data-tag-dot></span>}
  {hasAvatar && (
    <span class="tag__avatar"><slot name="avatar" /></span>
  )}
  {hasIcon && (
    <span class="tag__icon"><slot name="icon" /></span>
  )}
  <span class="tag__text" data-tag-text>
    <slot />
  </span>
</span>
