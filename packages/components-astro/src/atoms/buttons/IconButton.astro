---
/**
 * IconButton (Atom)
 *
 * Icon-only button with hover rotation animation and loading states.
 * Uses the same token system as Button (--buttons-*).
 *
 * @param {"Primary" | "Secondary" | "Tertiary" | "Destructive Primary" | "Destructive Secondary" | "Destructive Tertiary"} variant - Button variant (default: "Primary")
 * @param {"xs" | "s" | "m" | "l" | "xl"} size - Button size (default: "m")
 * @param {string} href - If provided, renders as <a> tag instead of <button>
 * @param {string} label - Aria-label for accessibility (required for icon-only buttons)
 * @param {boolean} external - Opens link in new tab (only for href)
 * @param {boolean} disabled - Disabled state
 * @param {boolean} loading - Loading state with spinner
 * @param {string} class - Additional CSS classes
 *
 * Slots:
 * - default: Icon SVG content
 *
 * Data Attributes (Animation Contract):
 * - data-icon-button: Root element (discovery)
 * - data-hover-rotate: Enables hover rotate animation (via @atomchat/animations)
 * - data-icon-button-icon: Icon wrapper (animated on hover)
 * - data-icon-button-icon-clone: Clone icon (animated on hover)
 * - data-button-spinner: Loading spinner
 *
 * Usage:
 * <IconButton variant="Primary" size="m" label="Delete">
 *   <svg>...</svg>
 * </IconButton>
 * <IconButton variant="Secondary" loading label="Loading">
 *   <svg>...</svg>
 * </IconButton>
 * <IconButton variant="Tertiary" href="/settings" label="Settings">
 *   <svg>...</svg>
 * </IconButton>
 *
 * @see packages/animations/src/hover.ts — initHoverRotate()
 * @see packages/animations/src/loading.ts — spinner rotation
 */

interface Props {
  variant?: "Primary" | "Secondary" | "Tertiary" | "Destructive Primary" | "Destructive Secondary" | "Destructive Tertiary";
  size?: "xs" | "s" | "m" | "l" | "xl";
  href?: string;
  label?: string;
  external?: boolean;
  disabled?: boolean;
  loading?: boolean;
  class?: string;
  [key: string]: any;
}

const {
  variant = "Primary",
  size = "m",
  href,
  label,
  external = false,
  disabled = false,
  loading = false,
  class: className = "",
  ...rest
} = Astro.props;

// Variant mapping (same as Button)
const variantMap: Record<string, string> = {
  "Primary": "primary",
  "Secondary": "secondary",
  "Tertiary": "tertiary",
  "Destructive Primary": "danger-primary",
  "Destructive Secondary": "danger-secondary",
  "Destructive Tertiary": "danger-tertiary"
};
const tokenVariant = variantMap[variant];

const Tag = href ? "a" : "button";
const externalAttrs = href && external ? { target: "_blank", rel: "noopener noreferrer" } : {};
---

<Tag
  class:list={[
    "icon-button",
    `icon-button--${tokenVariant}`,
    `icon-button--${size}`,
    { "icon-button--disabled": disabled, "icon-button--loading": loading },
    className
  ]}
  data-icon-button
  data-hover-rotate
  {...href ? { href } : { type: "button" }}
  {...label ? { "aria-label": label } : {}}
  {...(disabled || loading) ? { disabled: true, "aria-disabled": "true" } : {}}
  {...loading ? { "aria-busy": "true" } : {}}
  {...externalAttrs}
  {...rest}
>
  <span class="icon-button__icon-wrap">
    <span class="icon-button__icon" data-icon-button-icon>
      <slot />
    </span>
    <span class="icon-button__icon icon-button__icon--clone" data-icon-button-icon-clone aria-hidden="true">
      <slot />
    </span>
  </span>
  {loading && (
    <span class="icon-button__loader" aria-hidden="true">
      <span class="icon-button__spinner" data-button-spinner></span>
    </span>
  )}
</Tag>
