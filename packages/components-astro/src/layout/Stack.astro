---
/**
 * Stack (Layout Primitive)
 *
 * Vertical flex layout with consistent gap between children.
 * Use for vertical lists, forms, card stacks, or any vertically-arranged content.
 *
 * @param {"xs" | "s" | "m" | "l" | "xl"} gap - Space between children (default: "m")
 * @param {"start" | "center" | "end" | "stretch"} align - Horizontal alignment (default: "stretch")
 * @param {"start" | "center" | "end" | "between" | "around"} justify - Vertical alignment (default: "start")
 * @param {boolean} fullHeight - Make stack take full height (default: false)
 * @param {string} as - HTML element tag (default: "div")
 * @param {string} class - Additional CSS classes
 *
 * Usage:
 * <Stack gap="m">
 *   <Card />
 *   <Card />
 *   <Card />
 * </Stack>
 *
 * <Stack gap="l" align="center" fullHeight>
 *   <Logo />
 *   <Nav />
 *   <Footer />
 * </Stack>
 *
 * @see packages/css/src/layout/stack.css
 * @see packages/tokens/src/components/layout.json
 */

interface Props {
  gap?: "xs" | "s" | "m" | "l" | "xl";
  align?: "start" | "center" | "end" | "stretch";
  justify?: "start" | "center" | "end" | "between" | "around";
  fullHeight?: boolean;
  as?: string;
  class?: string;
  [key: string]: any;
}

const {
  gap = "m",
  align = "stretch",
  justify = "start",
  fullHeight = false,
  as = "div",
  class: className = "",
  ...rest
} = Astro.props;

const Element = as;
---

<Element
  class:list={[
    "stack",
    `stack--gap-${gap}`,
    align !== "stretch" && `stack--align-${align}`,
    justify !== "start" && `stack--justify-${justify}`,
    fullHeight && "stack--full-height",
    className
  ]}
  data-stack
  {...rest}
>
  <slot />
</Element>
