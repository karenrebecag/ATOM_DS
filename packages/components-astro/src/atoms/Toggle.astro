---
/**
 * Toggle (Atom)
 *
 * Switch control for binary on/off states with support for labels and error states.
 * Follows ARIA switch pattern with semantic HTML and proper accessibility.
 *
 * @param {string} name - Required. Unique identifier for the toggle input
 * @param {"s" | "m"} size - Toggle size variant (default: "s")
 * @param {boolean} checked - Checked state (default: false)
 * @param {boolean} disabled - Disabled state (default: false)
 * @param {string} supportiveText - Optional supportive text below label
 * @param {boolean} error - Error state flag (default: false)
 * @param {string} errorText - Error message text (shown when error=true)
 * @param {string} class - Additional CSS classes
 *
 * Slots:
 * - default: Label text (optional)
 *
 * Data Attributes (Animation Contract):
 * - data-toggle: Root element (discovery)
 * - data-toggle-track: Track element
 * - data-toggle-knob: Knob element
 *
 * Rendering Modes:
 * - Bare mode: No label/supportiveText/error → renders minimal toggle
 * - Field mode: Has label/supportiveText/error → renders with toggle-field wrapper
 *
 * Usage:
 * <Toggle name="notifications">Enable notifications</Toggle>
 * <Toggle name="dark-mode" checked size="m">Dark mode</Toggle>
 * <Toggle name="terms" supportiveText="Required to continue">Accept terms</Toggle>
 * <Toggle name="invalid" error errorText="This option is required">Required field</Toggle>
 * <Toggle name="disabled-toggle" disabled>Disabled toggle</Toggle>
 *
 * @see packages/css/src/components/toggle.css
 * @see packages/tokens/src/components/toggle.json
 */

interface Props {
  name: string;
  size?: "s" | "m";
  checked?: boolean;
  disabled?: boolean;
  supportiveText?: string;
  error?: boolean;
  errorText?: string;
  class?: string;
  [key: string]: any;
}

const {
  name,
  size = "s",
  checked = false,
  disabled = false,
  supportiveText,
  error = false,
  errorText,
  class: className = "",
  ...rest
} = Astro.props;

const id = `toggle-${name}`;
const hasLabel = Astro.slots.has("default");
const hasError = error && errorText;
---

{hasLabel || supportiveText || hasError ? (
  <div
    class:list={[
      "toggle-field",
      `toggle-field--${size}`,
      { "toggle-field--disabled": disabled, "toggle-field--error": hasError },
      className
    ]}
    data-toggle
  >
    <div class="toggle-field__row">
      <div class="toggle-field__selector">
        <label class:list={["toggle", `toggle--${size}`]} for={id}>
          <input
            class="toggle__input"
            type="checkbox"
            id={id}
            name={name}
            checked={checked}
            disabled={disabled}
            role="switch"
            aria-checked={checked ? "true" : "false"}
            {...rest}
          />
          <span class="toggle__track" aria-hidden="true" data-toggle-track>
            <span class="toggle__knob" data-toggle-knob></span>
          </span>
        </label>
      </div>
      <div class="toggle-field__text">
        {hasLabel && (
          <label class="toggle-field__title" for={id}>
            <slot />
          </label>
        )}
        {supportiveText && (
          <span class="toggle-field__supportive">{supportiveText}</span>
        )}
      </div>
    </div>
    {hasError && (
      <div class="toggle-field__error">
        <svg class="toggle-field__error-icon" viewBox="0 0 16 16" fill="currentColor">
          <path d="M8 1a7 7 0 1 0 0 14A7 7 0 0 0 8 1Zm-.75 4a.75.75 0 0 1 1.5 0v3.5a.75.75 0 0 1-1.5 0V5Zm.75 7a1 1 0 1 1 0-2 1 1 0 0 1 0 2Z"/>
        </svg>
        <span class="toggle-field__error-text">{errorText}</span>
      </div>
    )}
  </div>
) : (
  <label
    class:list={["toggle", `toggle--${size}`, { "toggle--disabled": disabled }, className]}
    for={id}
    data-toggle
  >
    <input
      class="toggle__input"
      type="checkbox"
      id={id}
      name={name}
      checked={checked}
      disabled={disabled}
      role="switch"
      aria-checked={checked ? "true" : "false"}
      {...rest}
    />
    <span class="toggle__track" aria-hidden="true" data-toggle-track>
      <span class="toggle__knob" data-toggle-knob></span>
    </span>
  </label>
)}
