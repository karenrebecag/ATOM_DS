---
/**
 * Text
 *
 * Body text component with truncation and animation support.
 * Flexible element type (p, span, div, li) with responsive text control.
 *
 * @param {string} as - HTML element (default: "p")
 *   Options: "p" | "span" | "div" | "li"
 * @param {string} size - Text size (default: "body")
 *   Options: "body" | "caption" | "label" | "label-small" | "footnote"
 * @param {string} weight - Font weight (default: "regular")
 *   Options: "regular" | "medium" | "bold"
 * @param {string} color - Text color CSS var or "inherit" (default: "inherit")
 * @param {string} align - Text alignment (default: "left")
 *   Options: "left" | "center" | "right"
 * @param {boolean | number} truncate - Truncation mode (default: false)
 *   - true: Single line with ellipsis
 *   - number: Multi-line clamp with -webkit-line-clamp
 * @param {boolean} balance - Enable text-wrap: balance (default: false)
 * @param {string | false} animate - Animation type (default: false)
 *   Options: "masked-lines" | "masked-words" | "fade-up-load" |
 *            "scramble-load" | "scramble-scroll" | "highlight-scroll"
 * @param {string} trigger - Animation trigger (default: "scroll")
 *   Options: "scroll" | "load"
 * @param {number} delay - Animation delay in seconds (default: 0)
 * @param {string} class - Additional CSS classes
 *
 * Usage:
 * <Text>Regular paragraph text.</Text>
 * <Text size="caption" color="var(--fg-secondary)">Caption text</Text>
 * <Text truncate={3}>Long text that will be clamped to 3 lines...</Text>
 * <Text as="span" animate="fade-up-load">Animated inline text</Text>
 */

interface Props {
  as?: "p" | "span" | "div" | "li";
  size?: "body" | "caption" | "label" | "label-small" | "footnote";
  weight?: "regular" | "medium" | "bold";
  color?: string;
  align?: "left" | "center" | "right";
  truncate?: boolean | number;
  balance?: boolean;
  animate?: "masked-lines" | "masked-words" | "fade-up-load" | "scramble-load" | "scramble-scroll" | "highlight-scroll" | false;
  trigger?: "scroll" | "load";
  delay?: number;
  class?: string;
  [key: string]: any;
}

const {
  as = "p",
  size = "body",
  weight = "regular",
  color = "inherit",
  align = "left",
  truncate = false,
  balance = false,
  animate = false,
  trigger = "scroll",
  delay = 0,
  class: className = "",
  ...rest
} = Astro.props;

// ── Build inline style for clamp lines ──
const clampStyle = typeof truncate === "number" ? `--text-clamp-lines: ${truncate}` : undefined;
const colorStyle = color !== "inherit" ? `color: ${color}` : undefined;
const inlineStyle = [clampStyle, colorStyle].filter(Boolean).join("; ") || undefined;

// ── Dynamic HTML Tag ──
const Tag = as;
---

<Tag
  class:list={[
    "text",
    `text--${size}`,
    `text--${weight}`,
    `text--${align}`,
    { "text--truncate": truncate === true },
    { "text--clamp": typeof truncate === "number" },
    { "text--balance": balance },
    className,
  ]}
  style={inlineStyle}
  data-text
  data-text-animate={animate || undefined}
  data-text-trigger={animate ? trigger : undefined}
  data-text-split="lines"
  data-text-delay={delay > 0 ? delay.toString() : undefined}
  {...rest}
>
  <slot />
</Tag>
