      "import": "./dist/logo-wall.js",
      "types": "./dist/logo-wall.d.ts"
    },
    "./marquee": {
      "import": "./dist/marquee.js",
      "types": "./dist/marquee.d.ts"
    },
    "./motion": {
      "import": "./dist/motion.js",
      "types": "./dist/motion.d.ts"
    },
    "./odometer": {
      "import": "./dist/odometer.js",
      "types": "./dist/odometer.d.ts"
    },
    "./page-transition": {
      "import": "./dist/page-transition.js",
      "types": "./dist/page-transition.d.ts"
